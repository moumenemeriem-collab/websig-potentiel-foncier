# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (production — définir USE_SQLITE=False)
USE_SQLITE=True
POSTGRES_DB=websig
POSTGRES_USER=websig
POSTGRES_PASSWORD=websig_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS (frontend Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
